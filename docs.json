{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Retab Docs",
  "logo": {
    "dark": "/logo/retab_bonbon.svg",
    "light": "/logo/retab_bonbon.svg"
  },
  "integrations": {
    "gtm": {
      "tagId": "GTM-K8T2LB6Q"
    }
  },
  "theme": "mint",
  "favicon": "/favicon.png",
  "rounded": "sharp",
  "codeBlock": {
    "mode": "dark"
  },
  "colors": {
    "primary": "#D02572",
    "light": "#F682CB",
    "dark": "#B5367A"
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:support@Retab.com"
    }
  ],
  "topbarCtaButton": {
    "type": "github",
    "href": "https://github.com/retab-dev/retab"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Site",
          "icon": "globe",
          "href": "https://retab.com"
        },
        {
          "anchor": "Github",
          "icon": "github",
          "href": "https://github.com/retab-dev/retab"
        },
        {
          "anchor": "Blog",
          "icon": "book",
          "href": "https://retab.substack.com"
        },
        {
          "anchor": "Community",
          "icon": "discord",
          "href": "https://discord.gg/vc5tWRPqag"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/introduction",
              "overview/quickstart",
              "overview/Build-your-Schema",
              "overview/Best-practices"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "core-concepts/Core_Concepts",
              "core-concepts/Documents",
              "core-concepts/Files",
              "core-concepts/Parse",
              "core-concepts/Extract",
              "core-concepts/Chunking",
              "core-concepts/Edit",
              "core-concepts/Split",
              "core-concepts/Classify",
              "core-concepts/Reasoning",
              "core-concepts/Sources",
              "core-concepts/Extractions",
              "core-concepts/Jobs",
              "core-concepts/Pricing",
              "core-concepts/k-LLMs_Consensus"

            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "workflows/Workflows",
              "workflows/MCP",
              "workflows/Blocks",
              "workflows/Functions"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "terminal",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Files",
            "pages": [
              "api-reference/files/upload",
              "api-reference/files/list",
              "api-reference/files/get",
              "api-reference/files/download-link"
            ]
          },
          {
            "group": "Schemas",
            "pages": [
              "api-reference/schemas/generate"
            ]
          },
          {
            "group": "Documents",
            "pages": [
              "api-reference/documents/extract",
              "api-reference/documents/parse",
              "api-reference/documents/edit",
              "api-reference/documents/split",
              "api-reference/documents/classify"
            ]
          },
          {
            "group": "Edit",
            "pages": [
              {
                "group": "Agent",
                "pages": [
                  "api-reference/edit/agent/fill"
                ]
              },
              {
                "group": "Templates",
                "pages": [
                  "api-reference/edit/templates/generate",
                  "api-reference/edit/templates/fill"
                ]
              }
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "api-reference/workflows/list",
              "api-reference/workflows/get",
              "api-reference/workflows/runs/create",
              "api-reference/workflows/runs/get",
