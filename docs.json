                "group": "Steps",
                "pages": [
                  "api-reference/workflows/runs/steps/list",
                  "api-reference/workflows/runs/steps/get"
                ]
              }
            ]
          },
          {
            "group": "Jobs",
            "pages": [
              "api-reference/jobs/create",
              "api-reference/jobs/retrieve",
              "api-reference/jobs/status",
              "api-reference/jobs/list",
              "api-reference/jobs/delete",
              "api-reference/jobs/retry"
            ]
          },
          {
            "group": "Extractions",
            "pages": [
              "api-reference/extractions/list",
              "api-reference/extractions/get",
              "api-reference/extractions/sources"
            ]
          }

        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "cursor"
    ]
  },
  "redirects": [
    {
      "source": "/overview/core-concepts",
      "destination": "https://docs.retab.com/core-concepts/Core_Concepts",
